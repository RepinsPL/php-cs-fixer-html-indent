{
    "name": "repinspl/php-cs-fixer-html-indent",
    "description": "PHP-CS-Fixer custom fixers that preserve HTML-context indentation in mixed PHP/HTML files",
    "type": "library",
    "license": "MIT",
    "keywords": ["php-cs-fixer", "fixer", "html", "indentation", "blade", "template"],
    "authors": [
        {
            "name": "RepinsPL"
        }
    ],
    "support": {
        "issues": "https://github.com/repinspl/php-cs-fixer-html-indent/issues",
        "source": "https://github.com/repinspl/php-cs-fixer-html-indent"
    },
    "autoload": {
        "psr-4": {
            "RepinsPL\\PhpCsFixerHtmlIndent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RepinsPL\\PhpCsFixerHtmlIndent\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "scripts": {
        "test": "phpunit"
    }
}
